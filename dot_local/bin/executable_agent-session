#!/bin/bash
# Launch a Claude agent in a tmux session.
# Usage: agent-session <agent> [repo-path]
#
# If repo-path is omitted, defaults to the current directory.
#
# Examples:
#   agent-session nightingale              # uses $PWD
#   agent-session mcgill ~/github/hughcameron/hydrofoil

set -euo pipefail

AGENT="${1:?Usage: agent-session <agent> [repo-path]}"
REPO="${2:-$PWD}"

# Expand tilde
REPO="${REPO/#\~/$HOME}"

REPO_NAME="$(basename "$REPO")"
SESSION="${REPO_NAME}/${AGENT}"

# OS-specific permission mode
case "$(uname -s)" in
  Linux)  PERMS="--dangerously-skip-permissions" ;;
  Darwin) PERMS="" ;;
  *)      PERMS="" ;;
esac

exec tmux new-session -A -s "$SESSION" -c "$REPO" "claude --agent $AGENT $PERMS"
