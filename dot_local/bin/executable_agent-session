#!/bin/bash
# Launch a Claude agent in a tmux session.
# Usage: agent-session <agent> <repo-path>
#
# Examples:
#   agent-session mcgill ~/github/hughcameron/hydrofoil
#   agent-session nightingale ~/github/hughcameron/finetype

set -euo pipefail

AGENT="${1:?Usage: agent-session <agent> <repo-path>}"
REPO="${2:?Usage: agent-session <agent> <repo-path>}"

# Expand tilde
REPO="${REPO/#\~/$HOME}"

REPO_NAME="$(basename "$REPO")"
SESSION="${REPO_NAME}/${AGENT}"

exec tmux new-session -A -s "$SESSION" -c "$REPO" "claude --agent $AGENT --dangerously-skip-permissions"
