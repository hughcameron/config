#!/usr/bin/env bash
# finetype-dev — run the FineType CLI from the local working copy via cargo.
#
# Why: `finetype` (brew) is the stable installed binary. `finetype-dev`
# always runs the latest source in ~/github/meridian-online/finetype, so
# you can iterate on code without re-running `cargo install` and without
# tripping over which version is active.
#
# Usage: identical to `finetype`. Args are passed through verbatim.
#   finetype-dev profile -f data.csv -o json-schema > schema.json
#   finetype-dev validate data.csv schema.json --db out.db --table foo
#
# Build profile: dev (debug). The workspace's release profile uses
# `lto = true` + `codegen-units = 1`, which makes every recompile a
# multi-minute LTO relink and peaks RAM hard enough to OOM low-memory
# Linux hosts (e.g. the Beelink). Dev profile is 5–10× faster to compile
# and is the right default for iteration. For release-quality output use
# the brewed `finetype` binary or `make build`.
#
# This wrapper is macOS-only by design — it's a developer convenience for
# Hugh's Mac. On other hosts it exits cleanly with a pointer to `finetype`.

set -euo pipefail

if [[ "$(uname -s)" != "Darwin" ]]; then
  echo "finetype-dev: macOS-only wrapper (host: $(uname -s))." >&2
  echo "  On Linux, use the installed \`finetype\` binary instead." >&2
  exit 2
fi

REPO="${FINETYPE_REPO:-$HOME/github/meridian-online/finetype}"
MANIFEST="$REPO/crates/finetype-cli/Cargo.toml"

if [[ ! -f "$MANIFEST" ]]; then
  echo "finetype-dev: cannot find $MANIFEST" >&2
  echo "  Set FINETYPE_REPO to override (current: $REPO)" >&2
  exit 2
fi

exec cargo run --quiet --manifest-path "$MANIFEST" --bin finetype -- "$@"
