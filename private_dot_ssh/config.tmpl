{{ if eq .chezmoi.os "darwin" -}}
# Beelink Mini PC (LAN)
Host beelink
    HostName 192.168.1.160
    User hugh
    IdentityFile ~/.ssh/beelink_ed25519
    IdentitiesOnly yes

{{ end -}}
{{ if eq .chezmoi.os "linux" -}}
# GitHub SSH authentication (for clone/push)
Host github.com
    IdentityFile ~/.ssh/github_vm_access
    IdentitiesOnly yes
    StrictHostKeyChecking accept-new

# MacBook Pro — reverse access for clipboard bridge.
# Uses Tailscale MagicDNS so the hostname stays stable across LAN reconnects.
# Requires both ends authenticated to the same tailnet.
Host mac
    HostName hughs-macbook-pro
    User hugh
    IdentitiesOnly yes
    StrictHostKeyChecking accept-new
{{ end -}}
