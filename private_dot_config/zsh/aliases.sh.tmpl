# Aliases

# Chezmoi
alias cm='chezmoi'
alias cmts='cm-target-to-source'
alias cmup='cm-source-update'

# Homebrew
alias brewup='brew upgrade'

# Git
alias lg='lazygit'
alias gl='gh pr list'
alias gs='gh pr merge --squash'
alias gv='gh pr view'

# Claude (launches a tmux session named after the current git repo)
alias cc='claude-session'

# Navi
alias n='navi'

# Pipeline
alias pl='navi --query "pipeline" --best-match'

{{ if eq .chezmoi.os "darwin" -}}
# Remote agent sessions
alias bb='ssh beelink'
alias bba='navi --query "attach to existing tmux" --best-match'
alias bbts='ssh beelink-ts'
alias bbt='navi --query "attach to existing tmux (Tailscale)" --best-match'

# Finder / Terminal
alias peek='open .'
alias tap='open -a Terminal'

# Bear CLI
alias br='bcli'

# Msgvault
alias em='msgvault'

# Nushell analysis scripts (kept as nu invocations)
alias bt='nu ~/.config/nushell/analysis/brewtrend/brewtrend.nu'
alias ccu='nu ~/.config/nushell/analysis/claude-usage/claude-usage.nu'
alias gcpvm='nu ~/.config/nushell/scripts/gcpvm.nu'

# DuckDB via navi
alias dx='navi --query "duckdb -f <file>" --best-match'
alias dv='navi --query "duckdb -json -f <file> | vd -f json" --best-match'
alias dj='navi --query "duckdb -json -f <file> | jless" --best-match'
{{ end -}}

{{ if eq .chezmoi.os "linux" -}}
alias ci='curl -fsSL https://claude.ai/install.sh | bash'
{{ end -}}
