// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {
      "alt-shift-b": ["task::Spawn", { "task_name": "Run in BigQuery" }],
      "alt-shift-b v": ["task::Spawn", { "task_name": "BigQuery to Visidata" }],
      "alt-shift-b j": ["task::Spawn", { "task_name": "BigQuery to JLESS" }],
      "alt-shift-d": ["task::Spawn", { "task_name": "Run in DuckDB" }],
      "alt-shift-d v": ["task::Spawn", { "task_name": "DuckDB to Visidata" }],
      "alt-shift-d j": ["task::Spawn", { "task_name": "DuckDB to JLESS" }],
      "cmd-shift-t": "workspace::NewCenterTerminal",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "alt-shift-i": "editor::SplitSelectionIntoLines",
      "alt-shift-n": ["task::Spawn", { "task_name": "Run Script in Terminal" }],
      "alt-shift-n l": [
        "task::Spawn",
        { "task_name": "Run Selected Text in Terminal" },
      ],
      "alt-shift-g b": [
        "task::Spawn",
        { "task_name": "Browse Repository in GitHub" },
      ],
      // "j k": ["workspace::SendKeystrokes", "escape"]
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-shift-t": "pane::ReopenClosedItem"
    }
  },
  {
    "context": "Workspace",
    "unbind": {
      "cmd-shift-t": "pane::ReopenClosedItem"
    }
  },
  // Vim sneak: s + two chars to jump forward, S + two chars to jump backward
  {
    "context": "vim_mode == normal || vim_mode == visual",
    "bindings": {
      "s": "vim::PushSneak",
      "shift-s": "vim::PushSneakBackward"
    }
  },
  // Surround in visual mode: select text then S + char to wrap
  {
    "context": "vim_mode == visual",
    "bindings": {
      "shift-s": "vim::PushAddSurrounds"
    }
  },
  // Navigate into/out of docks (file tree, panels) with ctrl-w
  {
    "context": "Dock",
    "bindings": {
      "ctrl-w h": "workspace::ActivatePaneLeft",
      "ctrl-w l": "workspace::ActivatePaneRight",
      "ctrl-w k": "workspace::ActivatePaneUp",
      "ctrl-w j": "workspace::ActivatePaneDown"
    }
  }
]
